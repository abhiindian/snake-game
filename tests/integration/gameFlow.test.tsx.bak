import { describe, it, expect, vi } from 'vitest'
import { render, screen, fireEvent, waitFor } from '@testing-library/react'
import userEvent from '@testing-library/user-event'
import { Provider } from 'react-redux'
import { configureStore } from '@reduxjs/toolkit'
import { MemoryRouter, Route, Routes } from 'react-router-dom'
import { Home } from '@/pages/Home'
import { Game } from '@/pages/Game'
import gameReducer from '@/store/gameSlice'
import type { GameState } from '@/store/gameSlice'

function createTestStore(initialState?: Partial<GameState>) {
  return configureStore({
    reducer: {
      game: gameReducer,
    },
    preloadedState: {
      game: {
        status: 'idle',
        score: 0,
        gridSize: { width: 40, height: 40 },
        snake: [{ x: 20, y: 20 }, { x: 19, y: 20 }, { x: 18, y: 20 }],
        direction: { x: 1, y: 0 },
        nextDirection: { x: 1, y: 0 },
        food: { x: 25, y: 25 },
        tickSpeed: 120,
        ...initialState,
      },
    },
  })
}

function renderWithStore(
  store: ReturnType<typeof createTestStore>,
  initialRoute: string = '/'
) {
  return render(
    <MemoryRouter initialEntries={[initialRoute]}>
      <Provider store={store}>
        <Routes>
          <Route path="/" element={<Home />} />
          <Route path="/game" element={<Game />} />
        </Routes>
      </Provider>
    </MemoryRouter>
  )
}

describe('Integration: Home → Game Navigation Flow', () => {
  it('renders Home page with Start Game button', () => {
    const store = createTestStore()
    renderWithStore(store, '/')

    expect(screen.getByRole('heading', { name: /snake game/i })).toBeInTheDocument()
    expect(screen.getByRole('button', { name: /start game/i })).toBeInTheDocument()
  })

  it('navigates to Game page when Start Game is clicked', async () => {
    const store = createTestStore()
    renderWithStore(store, '/')

    const startButton = screen.getByRole('button', { name: /start game/i })
    await userEvent.click(startButton)

    // Game component redirects when status is idle, so we dispatch startGame first
    // Then wait for the game board to render
    await waitFor(() => {
      expect(store.getState().game.status).toBe('running')
    })

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })
  })
})

describe('Integration: Keyboard Input and Direction Changes', () => {
  it('changes direction when arrow keys are pressed', async () => {
    const store = createTestStore({ status: 'running' })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })

    const grid = screen.getByRole('grid', { name: /snake game board/i })

    // Press Arrow Right — should dispatch changeDirection({x: 1, y: 0})
    await userEvent.type(grid, '{arrowright}')

    // Direction change should not cause errors
    expect(grid).toBeInTheDocument()
  })

  it('changes direction when WASD keys are pressed', async () => {
    const store = createTestStore({ status: 'running' })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })

    const grid = screen.getByRole('grid', { name: /snake game board/i })

    // Press W — should dispatch changeDirection({x: 0, y: -1})
    await userEvent.type(grid, 'w')

    expect(grid).toBeInTheDocument()
  })
})

describe('Integration: Food Consumption and Score Increment', () => {
  it('displays score on the Scoreboard', async () => {
    const store = createTestStore({ status: 'running', score: 30 })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })

    // Scoreboard should show the score
    expect(screen.getByText('30')).toBeInTheDocument()
  })

  it('updates score display after score changes', async () => {
    const store = createTestStore({ status: 'running', score: 0 })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })

    // Initial score is 0
    expect(screen.getByText('0')).toBeInTheDocument()

    // Dispatch a tick to increment score (simulates eating food)
    store.dispatch({ type: 'game/tick' })
    store.dispatch({ type: 'game/tick' })

    // Score should have increased
    await waitFor(() => {
      const scoreText = screen.getByText(/\d+/)
      expect(scoreText).toBeInTheDocument()
    })
  })
})

describe('Integration: Collision Detection and Game Over State', () => {
  it('shows Game Over overlay when game status is gameOver', async () => {
    const store = createTestStore({
      status: 'gameOver',
      score: 50,
    })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('alert', { name: /game over/i })).toBeInTheDocument()
      expect(screen.getByText(/game over/i)).toBeInTheDocument()
    })
  })

  it('triggers game over on wall collision via tick', async () => {
    const store = createTestStore({
      status: 'running',
      snake: [{ x: 39, y: 20 }, { x: 38, y: 20 }, { x: 37, y: 20 }],
      direction: { x: 1, y: 0 },
      nextDirection: { x: 1, y: 0 },
    })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })

    // Tick when head is at x=39 moving right → wall collision
    store.dispatch({ type: 'game/tick' })

    await waitFor(() => {
      expect(store.getState().game.status).toBe('gameOver')
    })

    // Game Over overlay should appear
    expect(screen.getByText(/game over/i)).toBeInTheDocument()
  })

  it('triggers game over on self collision via tick', async () => {
    // Snake coiled: head at (5,5), body at (5,4), (5,3), (6,3), (7,3)
    // Move up → (5,4) which is body → self collision
    const store = createTestStore({
      status: 'running',
      snake: [
        { x: 5, y: 5 },
        { x: 5, y: 4 },
        { x: 5, y: 3 },
        { x: 6, y: 3 },
        { x: 7, y: 3 },
      ],
      direction: { x: 0, y: -1 },
      nextDirection: { x: 0, y: -1 },
      food: { x: 10, y: 10 },
    })
    renderWithStore(store, '/game')

    // Tick will move head to (5,4) which is body segment → self collision
    store.dispatch({ type: 'game/tick' })

    await waitFor(() => {
      expect(store.getState().game.status).toBe('gameOver')
    })

    expect(screen.getByText(/game over/i)).toBeInTheDocument()
  })
})

describe('Integration: Pause/Resume Lifecycle', () => {
  it('pauses game when Space is pressed during running', async () => {
    const store = createTestStore({ status: 'running' })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })

    const grid = screen.getByRole('grid', { name: /snake game board/i })

    // Press Space to toggle pause
    await userEvent.type(grid, ' ')

    await waitFor(() => {
      expect(store.getState().game.status).toBe('paused')
    })

    // Should show Resume button
    expect(screen.getByRole('button', { name: /resume/i })).toBeInTheDocument()
  })

  it('resumes game when Space is pressed during paused', async () => {
    const store = createTestStore({ status: 'paused' })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })

    const grid = screen.getByRole('grid', { name: /snake game board/i })

    // Press Space to toggle resume
    await userEvent.type(grid, ' ')

    await waitFor(() => {
      expect(store.getState().game.status).toBe('running')
    })

    // Should show Pause button
    expect(screen.getByRole('button', { name: /pause/i })).toBeInTheDocument()
  })

  it('shows correct status label for playing, paused, and game over', async () => {
    // Playing
    const runningStore = createTestStore({ status: 'running' })
    renderWithStore(runningStore, '/game')
    await waitFor(() => {
      expect(screen.getByText(/▶ playing/i)).toBeInTheDocument()
    })

    // Paused
    const pausedStore = createTestStore({ status: 'paused' })
    renderWithStore(pausedStore, '/game')
    await waitFor(() => {
      expect(screen.getByText(/⏸ paused/i)).toBeInTheDocument()
    })

    // Game Over
    const gameOverStore = createTestStore({ status: 'gameOver' })
    renderWithStore(gameOverStore, '/game')
    await waitFor(() => {
      expect(screen.getByText(/game over/i)).toBeInTheDocument()
    })
  })
})

describe('Integration: Restart Flow', () => {
  it('restarts game from Game Over overlay', async () => {
    const store = createTestStore({ status: 'gameOver', score: 100 })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('alert', { name: /game over/i })).toBeInTheDocument()
    })

    // Click Restart button
    const restartButton = screen.getByRole('button', { name: /restart/i })
    await userEvent.click(restartButton)

    await waitFor(() => {
      // Status should be running after restart
      expect(store.getState().game.status).toBe('running')
      // Score should be reset to 0
      expect(store.getState().game.score).toBe(0)
    })

    // Game Over overlay should disappear
    await waitFor(() => {
      expect(screen.queryByText(/game over/i)).not.toBeInTheDocument()
    })
  })

  it('restarts game from GameControls toolbar', async () => {
    const store = createTestStore({ status: 'running', score: 50 })
    renderWithStore(store, '/game')

    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })

    // Click Restart in GameControls
    const restartButton = screen.getByRole('button', { name: /restart/i })
    await userEvent.click(restartButton)

    await waitFor(() => {
      expect(store.getState().game.status).toBe('running')
      expect(store.getState().game.score).toBe(0)
    })
  })
})

describe('Integration: Full Game Flow from Start to Game Over', () => {
  it('completes full game cycle: start → play → game over → restart', async () => {
    const store = createTestStore()
    renderWithStore(store, '/')

    // 1. Start game from Home
    await userEvent.click(screen.getByRole('button', { name: /start game/i }))

    // 2. Should be on Game page
    await waitFor(() => {
      expect(screen.getByRole('grid', { name: /snake game board/i })).toBeInTheDocument()
    })
    expect(store.getState().game.status).toBe('running')

    // 3. Play — press direction keys
    const grid = screen.getByRole('grid', { name: /snake game board/i })
    await userEvent.type(grid, '{arrowup}')

    // 4. Pause
    await userEvent.type(grid, ' ')
    await waitFor(() => {
      expect(store.getState().game.status).toBe('paused')
    })

    // 5. Resume
    await userEvent.type(grid, ' ')
    await waitFor(() => {
      expect(store.getState().game.status).toBe('running')
    })

    // 6. Cause game over by moving snake to wall
    store.dispatch({
      type: 'game/tick',
    })

    // Game should end
    await waitFor(() => {
      expect(screen.getByText(/game over/i)).toBeInTheDocument()
    })

    // 7. Restart
    await userEvent.click(screen.getByRole('button', { name: /restart/i }))

    // 8. Game should be running again with reset score
    await waitFor(() => {
      expect(store.getState().game.status).toBe('running')
      expect(store.getState().game.score).toBe(0)
      expect(screen.queryByText(/game over/i)).not.toBeInTheDocument()
    })
  })
})
